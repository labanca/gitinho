# =================================================================
# Gitinho chat (apps/chat) — variáveis de ambiente
# =================================================================
# Em desenvolvimento, copie este arquivo para apps/chat/.env.
# O .env do monorepo (na raiz) é a fonte canônica; este aqui é
# carregado pelo Next.js a partir do diretório do app.

# --- Database (compartilhada com migrations) ---------------------
POSTGRES_URL=postgres://gitinho:CHANGE_ME@localhost:5432/gitinho

# --- Better Auth -------------------------------------------------
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=GENERATE_ME
BETTER_AUTH_URL=http://localhost:3000

# --- GitHub OAuth (login do usuário) ----------------------------
# Reuso da OAuth App splor-mg/gitinho.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Bloqueios de cadastro --------------------------------------
# Mantém somente OAuth GitHub como caminho de login.
DISABLE_EMAIL_SIGN_IN=1
DISABLE_EMAIL_SIGN_UP=1
DISABLE_SIGN_UP=1

# --- Allowlist da organização (validação no callback) -----------
ALLOWED_ORG=splor-mg

# Allowlist opcional de logins do GitHub (CSV, case-insensitive). Vazio
# ou ausente = liberado para todos os membros de ALLOWED_ORG. Útil para
# ramp-up em rollouts iniciais.
# Exemplo: ALLOWED_USERS=labanca,fulano,sicrano
ALLOWED_USERS=

# --- Azure OpenAI via OpenAI-compatible adapter -----------------
# Cole o JSON gerado pelo helper do better-chatbot (script
# openai-compatiable:init) ou edite manualmente. Inclui base URL
# e modelos disponíveis.
OPENAI_COMPATIBLE_DATA=

# --- MCP (cliente apenas: aponta para apps/mcp) ------------------
FILE_BASED_MCP_CONFIG=true
NOT_ALLOW_ADD_MCP_SERVERS=1
# Timeout opcional (ms) para chamadas longas de ferramentas MCP.
MCP_MAX_TOTAL_TIMEOUT=

# --- File ingest -------------------------------------------------
# Driver: `s3` (MinIO/S3) ou `vercel-blob`.
FILE_STORAGE_TYPE=s3
FILE_STORAGE_PREFIX=uploads

# MinIO sidecar (compose/easypanel) — usado quando FILE_STORAGE_TYPE=s3.
# Em produção, troque por credenciais reais e endpoint público adequado.
FILE_STORAGE_S3_BUCKET=gitinho-uploads
FILE_STORAGE_S3_REGION=us-east-1
FILE_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
FILE_STORAGE_S3_FORCE_PATH_STYLE=1
FILE_STORAGE_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
