# ====================================================================
# Gitinho — variáveis de ambiente
# ====================================================================
# Copie este arquivo para `.env` e preencha os campos. Nunca commit `.env`.

# --- App ----------------------------------------------------------
ALLOWED_ORG=splor-mg

# Allowlist opcional de logins do GitHub (CSV, case-insensitive). Vazio
# ou ausente = liberado para todos os membros de ALLOWED_ORG. Útil para
# ramp-up em rollouts iniciais.
# Exemplo: ALLOWED_USERS=labanca,fulano,sicrano
ALLOWED_USERS=

# --- Postgres (compartilhado entre chat e migrations) ------------
POSTGRES_URL=postgres://gitinho:CHANGE_ME@localhost:5432/gitinho

# --- Better Auth (apps/chat) -------------------------------------
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=GENERATE_ME
BETTER_AUTH_URL=http://localhost:3000

# --- GitHub OAuth (login do usuário em apps/chat) ---------------
# Reuso da OAuth App splor-mg/gitinho existente.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Bloqueia caminhos de e-mail e cria-conta — somente OAuth GitHub.
DISABLE_EMAIL_SIGN_IN=1
DISABLE_EMAIL_SIGN_UP=1
DISABLE_SIGN_UP=1

# --- Azure OpenAI via OpenAI-compatible adapter (apps/chat) ----
# Cole o JSON gerado pelo helper do better-chatbot ou via
# openai-compatible.config.ts. Inclui base URL e modelos.
OPENAI_COMPATIBLE_DATA=

# --- Anthropic via Azure Foundry passthrough (apps/chat) ------
# Foundry expõe Claude com protocolo Anthropic-nativo em
# `https://<recurso>.services.ai.azure.com/anthropic/v1`. Setando esta
# variável faz o @ai-sdk/anthropic apontar para lá em vez de
# api.anthropic.com — a chave em ANTHROPIC_API_KEY passa a ser a do
# deployment Foundry (formato não-sk-ant). IMPORTANTE: inclua o `/v1`
# no fim — o SDK monta a URL como `{baseURL}/messages`. Deixe vazio
# para usar Anthropic direta (sk-ant-... em ANTHROPIC_API_KEY).
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

# --- GitHub App (apps/mcp — consultas read-only aos dados) ------
GH_APP_ID=
GH_APP_INSTALLATION_ID=
GH_APP_PRIVATE_KEY_PATH=./secrets/gh-app.pem

# --- Glossário (apps/mcp) ---------------------------------------
GLOSSARY_CACHE_TTL_S=300

# --- MCP (apps/chat → apps/mcp) ---------------------------------
FILE_BASED_MCP_CONFIG=true
NOT_ALLOW_ADD_MCP_SERVERS=1

# --- File ingest --------------------------------------------------
# Driver: `s3` (MinIO/S3) ou `vercel-blob`.
FILE_STORAGE_TYPE=s3
FILE_STORAGE_PREFIX=uploads

# MinIO sidecar (apps/chat/docker/compose.yml) — usado com FILE_STORAGE_TYPE=s3.
# Em produção, troque por credenciais reais e endpoint público adequado.
FILE_STORAGE_S3_BUCKET=gitinho-uploads
FILE_STORAGE_S3_REGION=us-east-1
FILE_STORAGE_S3_ENDPOINT=http://minio:9000
FILE_STORAGE_S3_FORCE_PATH_STYLE=1
FILE_STORAGE_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=CHANGE_ME_minio_secret

# --- Postgres (init do container) --------------------------------
# Usados pelo container `postgres` do compose.
POSTGRES_USER=gitinho
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=gitinho
