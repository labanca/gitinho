# ── App ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8080
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string-48-chars-minimum

# ── Organização alvo ───────────────────────────────────────────────
ALLOWED_ORG=splor-mg

# ── GitHub OAuth (login dos usuários) ──────────────────────────────
# Crie em https://github.com/settings/developers (ou na org)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8080/auth/github/callback

# ── GitHub App (acesso aos dados da org) ───────────────────────────
# Crie em https://github.com/organizations/<ORG>/settings/apps
# Instale na organização e anote o installation ID.
GH_APP_ID=
GH_APP_INSTALLATION_ID=
# Caminho para a chave privada (.pem) baixada do GitHub.
# Em dev local, coloque em ./secrets/gh-app.pem (já está no .gitignore).
GH_APP_PRIVATE_KEY_PATH=./secrets/gh-app.pem
# Ou (alternativa) cole o conteúdo do PEM inteiro como string:
# GH_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Azure OpenAI / Foundry ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<seu-recurso>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_DEPLOYMENT_ORCHESTRATOR=gpt-4.1
AZURE_DEPLOYMENT_ANALYTIC=o3
AZURE_DEPLOYMENT_LIGHT=gpt-4.1-mini

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gitinho:gitinho@localhost:5433/gitinho

# ── Agente ─────────────────────────────────────────────────────────
AGENT_ALLOW_WRITE=false
AGENT_MAX_STEPS=12
AGENT_TIMEOUT_S=120

# ── MCP ────────────────────────────────────────────────────────────
MCP_GITHUB_ENABLED=true
MCP_GITHUB_COMMAND=github-mcp-server
MCP_GITHUB_ARGS=stdio

# ── Rate-limit ─────────────────────────────────────────────────────
RATE_LIMIT_USER_PER_MIN=60
RATE_LIMIT_IP_PER_MIN=20

# ── Logs ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
